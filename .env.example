## ─────────────────────────────────────────────────────────────────────────
## EngineeringAgent — Environment Variables Template
## Copy this file to .env and fill in the values.
## NEVER commit .env to Git.
## ─────────────────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME="EngineeringAgent"
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
# Use stderr on Render/Docker — file-based logs don't persist on ephemeral disks
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (PostgreSQL for Render) ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=engineering_agent
DB_USERNAME=agent_user
DB_PASSWORD=your_strong_password_here

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail (set to log for now — configure SMTP when needed) ──────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 (optional — only needed for cloud file storage) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── AI / Ollama ───────────────────────────────────────────────────────────────
# On Render: Ollama is not available. The app falls back to mock reports automatically.
# For local Docker: points to host machine Ollama via host.docker.internal
AI_PROVIDER=ollama
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# ── GitHub Integration (optional) ─────────────────────────────────────────────
# If set, VCS sync uses the real GitHub API. If empty, simulation mode is used.
GITHUB_TOKEN=

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
